description=package MEUS.TESTES;  import javax.swing.*; import java.awt.*; import java.awt.event.*; import java.text.DecimalFormat;  public class Calculator extends JFrame {      // \u2500\u2500\u2500 State \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500     private double firstOperand  \= 0;     private double secondOperand \= 0;     private String operator      \= "";     private boolean freshInput   \= true;     private boolean justEvaled   \= false;      // \u2500\u2500\u2500 UI Components \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500     private JLabel expressionLabel;     private JLabel displayLabel;      // \u2500\u2500\u2500 Palette \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500     private static final Color BG          \= new Color(0x1C1C1E);     private static final Color DISPLAY_BG  \= new Color(0x1C1C1E);     private static final Color BTN_FUNC    \= new Color(0x3A3A3C);     private static final Color BTN_OP      \= new Color(0xFF9F0A);     private static final Color BTN_NUM     \= new Color(0x2C2C2E);     private static final Color BTN_ZERO    \= new Color(0x2C2C2E);     private static final Color TXT_LIGHT   \= Color.WHITE;     private static final Color TXT_DARK    \= Color.BLACK;      // \u2500\u2500\u2500 Constructor \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500     public Calculator() {         super("Calculator");         buildUI();         attachKeyboardSupport();         setVisible(true);     }      // \u2500\u2500\u2500 UI Builder \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500     private void buildUI() {         setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);         setResizable(false);         setBackground(BG);         getContentPane().setBackground(BG);          JPanel root \= new JPanel(new BorderLayout());         root.setBackground(BG);         root.setBorder(BorderFactory.createEmptyBorder(20, 16, 16, 16));          root.add(buildDisplay(), BorderLayout.NORTH);         root.add(buildButtonGrid(), BorderLayout.CENTER);          add(root);         pack();         setMinimumSize(new Dimension(320, 480));         setLocationRelativeTo(null);     }      private JPanel buildDisplay() {         JPanel panel \= new JPanel();         panel.setLayout(new BoxLayout(panel, BoxLayout.Y_AXIS));         panel.setBackground(DISPLAY_BG);         panel.setBorder(BorderFactory.createEmptyBorder(0, 8, 12, 8));          expressionLabel \= new JLabel(" ");         expressionLabel.setFont(new Font("SansSerif", Font.PLAIN, 16));         expressionLabel.setForeground(new Color(0x8E8E93));         expressionLabel.setAlignmentX(Component.RIGHT_ALIGNMENT);          displayLabel \= new JLabel("0");         displayLabel.setFont(new Font("SansSerif", Font.PLAIN, 64));         displayLabel.setForeground(TXT_LIGHT);         displayLabel.setAlignmentX(Component.RIGHT_ALIGNMENT);          panel.add(expressionLabel);         panel.add(displayLabel);         return panel;     }      private JPanel buildButtonGrid() {         JPanel grid \= new JPanel(new GridLayout(5, 4, 10, 10));         grid.setBackground(BG);          addButton(grid, "AC",  BTN_FUNC,  TXT_DARK,  this\:\:handleAC);         addButton(grid, "+/-", BTN_FUNC,  TXT_DARK,  this\:\:handleToggleSign);         addButton(grid, "%",   BTN_FUNC,  TXT_DARK,  this\:\:handlePercent);         addButton(grid, "\u00F7",   BTN_OP,    TXT_LIGHT, () -> handleOperator("\u00F7"));          addButton(grid, "7",   BTN_NUM,   TXT_LIGHT, () -> handleDigit("7"));         addButton(grid, "8",   BTN_NUM,   TXT_LIGHT, () -> handleDigit("8"));         addButton(grid, "9",   BTN_NUM,   TXT_LIGHT, () -> handleDigit("9"));         addButton(grid, "\u00D7",   BTN_OP,    TXT_LIGHT, () -> handleOperator("\u00D7"));          addButton(grid, "4",   BTN_NUM,   TXT_LIGHT, () -> handleDigit("4"));         addButton(grid, "5",   BTN_NUM,   TXT_LIGHT, () -> handleDigit("5"));         addButton(grid, "6",   BTN_NUM,   TXT_LIGHT, () -> handleDigit("6"));         addButton(grid, "\u2212",   BTN_OP,    TXT_LIGHT, () -> handleOperator("\u2212"));          addButton(grid, "1",   BTN_NUM,   TXT_LIGHT, () -> handleDigit("1"));         addButton(grid, "2",   BTN_NUM,   TXT_LIGHT, () -> handleDigit("2"));         addButton(grid, "3",   BTN_NUM,   TXT_LIGHT, () -> handleDigit("3"));         addButton(grid, "+",   BTN_OP,    TXT_LIGHT, () -> handleOperator("+"));          JPanel zeroPanel \= makeWideButton("0", TXT_LIGHT, () -> handleDigit("0"));         grid.add(zeroPanel);         addButton(grid, ".",   BTN_NUM,   TXT_LIGHT, this\:\:handleDot);         addButton(grid, "\=",   BTN_OP,    TXT_LIGHT, this\:\:handleEquals);          return grid;     }      private void addButton(JPanel parent, String text, Color bg, Color fg, Runnable action) {         JButton btn \= new JButton(text);         btn.setBackground(bg);         btn.setForeground(fg);         btn.setFocusPainted(false);         btn.setBorderPainted(false);         btn.setOpaque(true);         btn.setFont(new Font("SansSerif", Font.BOLD, 20));         btn.addActionListener(e -> action.run());         parent.add(btn);     }      private JPanel makeWideButton(String text, Color fg, Runnable action) {         JPanel wrapper \= new JPanel(new GridLayout(1, 1));         wrapper.setBackground(BG);         JButton btn \= new JButton(text);         btn.setBackground(Calculator.BTN_ZERO);         btn.setForeground(fg);         btn.setFocusPainted(false);         btn.setBorderPainted(false);         btn.setOpaque(true);         btn.setFont(new Font("SansSerif", Font.BOLD, 20));         btn.setHorizontalAlignment(SwingConstants.LEFT);         btn.setBorder(BorderFactory.createEmptyBorder(0, 28, 0, 0));         btn.addActionListener(e -> action.run());         wrapper.add(btn);         return wrapper;     }      // \u2500\u2500\u2500 Logic (Refactored for Java 8) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500     private void handleDigit(String d) {         String current \= displayLabel.getText();         if (freshInput || justEvaled) {             displayLabel.setText(d);             freshInput   \= false;             justEvaled   \= false;         } else {             if (current.length() >\= 12) return;             displayLabel.setText(current.equals("0") ? d \: current + d);         }     }      private void handleDot() {         String current \= displayLabel.getText();         if (freshInput || justEvaled) {             displayLabel.setText("0.");             freshInput \= false;             justEvaled \= false;         } else if (\!current.contains(".")) {             displayLabel.setText(current + ".");         }     }      private void handleOperator(String op) {         firstOperand \= parseDisplay();         operator     \= op;         freshInput   \= true;         justEvaled   \= false;         expressionLabel.setText(formatNumber(firstOperand) + " " + op);     }      private void handleEquals() {         secondOperand \= parseDisplay();         String expr   \= formatNumber(firstOperand) + " " + operator + " " + formatNumber(secondOperand) + " \=";         expressionLabel.setText(expr);          double result \= compute(firstOperand, secondOperand, operator);         displayLabel.setText(formatNumber(result));          firstOperand \= result;         operator     \= "";         freshInput   \= true;         justEvaled   \= true;     }      private void handleAC() {         firstOperand  \= 0;         secondOperand \= 0;         operator      \= "";         freshInput    \= true;         justEvaled    \= false;         displayLabel.setText("0");         expressionLabel.setText(" ");     }      private void handleToggleSign() {         double val \= parseDisplay();         displayLabel.setText(formatNumber(-val));     }      private void handlePercent() {         double val \= parseDisplay();         displayLabel.setText(formatNumber(val / 100.0));     }      // Refactored Switch for Java 8     private double compute(double a, double b, String op) {         switch (op) {             case "+"\:                 return a + b;             case "\u2212"\:                 return a - b;             case "\u00D7"\:                 return a * b;             case "\u00F7"\:                 return (b \=\= 0) ? handleDivByZero() \: a / b;             default\:                 return b;         }     }      private double handleDivByZero() {         expressionLabel.setText("Error\: division by zero");         freshInput \= true;         return 0;     }      private double parseDisplay() {         try {             return Double.parseDouble(displayLabel.getText().replace("\u2212", "-"));         } catch (NumberFormatException e) {             return 0;         }     }      private String formatNumber(double n) {         if (Double.isInfinite(n) || Double.isNaN(n)) return "Error";         if (n \=\= Math.floor(n) && Math.abs(n) < 1e12) {             return new DecimalFormat("\#,\#\#0.\#\#\#\#\#\#\#\#").format(n);         }         DecimalFormat df \= new DecimalFormat("0.\#\#\#\#\#\#\#\#E0");         return df.format(n);     }      // \u2500\u2500\u2500 Keyboard Support (Refactored for Java 8) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500     private void attachKeyboardSupport() {         addKeyListener(new KeyAdapter() {             @Override public void keyPressed(KeyEvent e) {                 int code \= e.getKeyCode();                 // Java 8 requires stacked cases                 switch (code) {                     case KeyEvent.VK_0\:                     case KeyEvent.VK_NUMPAD0\:                         handleDigit("0"); break;                     case KeyEvent.VK_1\:                     case KeyEvent.VK_NUMPAD1\:                         handleDigit("1"); break;                     case KeyEvent.VK_2\:                     case KeyEvent.VK_NUMPAD2\:                         handleDigit("2"); break;                     case KeyEvent.VK_3\:                     case KeyEvent.VK_NUMPAD3\:                         handleDigit("3"); break;                     case KeyEvent.VK_4\:                     case KeyEvent.VK_NUMPAD4\:                         handleDigit("4"); break;                     case KeyEvent.VK_5\:                     case KeyEvent.VK_NUMPAD5\:                         handleDigit("5"); break;                     case KeyEvent.VK_6\:                     case KeyEvent.VK_NUMPAD6\:                         handleDigit("6"); break;                     case KeyEvent.VK_7\:                     case KeyEvent.VK_NUMPAD7\:                         handleDigit("7"); break;                     case KeyEvent.VK_8\:                     case KeyEvent.VK_NUMPAD8\:                         handleDigit("8"); break;                     case KeyEvent.VK_9\:                     case KeyEvent.VK_NUMPAD9\:                         handleDigit("9"); break;                     case KeyEvent.VK_PERIOD\:                     case KeyEvent.VK_DECIMAL\:                         handleDot(); break;                     case KeyEvent.VK_ADD\:                         handleOperator("+"); break;                     case KeyEvent.VK_MINUS\:                     case KeyEvent.VK_SUBTRACT\:                         handleOperator("\u2212"); break;                     case KeyEvent.VK_MULTIPLY\:                         handleOperator("\u00D7"); break;                     case KeyEvent.VK_DIVIDE\:                     case KeyEvent.VK_SLASH\:                         handleOperator("\u00F7"); break;                     case KeyEvent.VK_ENTER\:                     case KeyEvent.VK_EQUALS\:                         handleEquals(); break;                     case KeyEvent.VK_ESCAPE\:                     case KeyEvent.VK_DELETE\:                         handleAC(); break;                     case KeyEvent.VK_BACK_SPACE\:                         handleBackspace(); break;                 }             }         });         setFocusable(true);     }      private void handleBackspace() {         if (freshInput) return;         String cur \= displayLabel.getText();         if (cur.length() <\= 1 || cur.equals("-0")) {             displayLabel.setText("0");             freshInput \= true;         } else {             displayLabel.setText(cur.substring(0, cur.length() - 1));         }     }      public static void main(String[] args) {         try {             UIManager.setLookAndFeel(UIManager.getSystemLookAndFeelClassName());         } catch (Exception ignored) {}          SwingUtilities.invokeLater(new Runnable() {             @Override             public void run() {                 new Calculator();             }         });     } }
